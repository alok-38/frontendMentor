# =========================

# Frontend Mentor .gitignore

# =========================

# ---- Dependencies ----

node_modules/
jspm_packages/
.pnp/
.pnp.js

# ---- Build outputs ----

dist/
build/
.out/
.next/
.nuxt/
.svelte-kit/
coverage/

# ---- Logs ----

logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ---- Environment variables ----

.env
.env.*
!.env.example

# ---- OS files ----

.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# ---- Editor / IDE ----

.vscode/
.idea/
*.swp
*.swo
*.tmp
*.bak

# ---- Package managers ----

package-lock.json
yarn.lock
pnpm-lock.yaml

# (Optional: keep lock files for consistency)

# !package-lock.json

# !yarn.lock

# !pnpm-lock.yaml

# ---- Cache ----

.cache/
.parcel-cache/
.eslintcache
.stylelintcache

# ---- Testing ----

coverage/
.nyc_output/

# ---- Storybook ----

storybook-static/

# ---- Misc ----

*.tgz
*.zip

# ---- Frontend Mentor specific ----

# Ignore design files if you don't want to track them

*.fig
*.sketch
*.xd

# Ignore downloaded assets if needed

design/
downloads/

# Keep important project files

!README.md
!style-guide.md

# ---- Vite ----

vite.svg

# ---- Next.js ----

.next/
out/

# ---- Nuxt ----

.nuxt/
.output/

# ---- SvelteKit ----

.svelte-kit/

# ---- Temporary files ----

*.temp
*.temp.*

